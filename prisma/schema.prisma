generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===================================
// MODELO INGRAM MICRO (CATÁLOGO ÚNICO)
// ===================================

model Product {
  id           Int      @id @default(autoincrement())
  
  ingramSku    String   @unique // El SKU universal que usarás de Ingram
  mpn          String?  // SKU del Fabricante
  upc          String?  // Código de Barras
  
  title        String
  description  String?  @db.Text
  brand        String?
  category     String?
  imageUrl     String?
  gallery      Json?    // Array de URLs para la galería tipo Mercado Libre

  // Datos Financieros y Operativos (Directos de Ingram)
  price        Float    @default(0.0) // Precio MXN directo de Ingram
  stock        Int      @default(0)   // Stock global o de Bodega Central
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relaciones Inversas
  cartItems    Cart[]
  orderItems   OrderItem[]
}

// ===================================
// USUARIOS Y AUTENTICACIÓN
// ===================================

model User {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  password       String   // bcrypt hash
  nombres        String?
  apellidos      String?
  telefono       String?
  rfc            String?
  
  // Preferencias
  cart_msi       Boolean  @default(false)
  is_verified    Boolean  @default(true)

  // Relaciones
  orders         Order[]
  cartItems      Cart[]
  addresses      Address[]
  taxInvoices    TaxInvoice[]
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ===================================
// CARRITO DE COMPRAS
// ===================================

model Cart {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  productId  Int
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  quantity   Int      @default(1)
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, productId])
}

// ===================================
// ÓRDENES Y PAGOS (CHECKOUT)
// ===================================

model Order {
  id             Int          @id @default(autoincrement())
  userId         Int
  user           User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  
  // Totales
  subtotal       Float        @default(0.0)
  shipping       Float        @default(150.0)
  total          Float        @default(0.0)
  
  // Estado
  status         OrderStatus  @default(PENDING)
  paymentId      String?      // ID de MercadoPago, PayPal, etc.
  paymentMethod  String?      // 'mercadopago', 'paypal', etc.
  
  // Datos Ingram
  ingramOrderId  String?      // OrderNumber regresado por Ingram
  
  items          OrderItem[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model OrderItem {
  id         Int      @id @default(autoincrement())
  orderId    Int
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId  Int
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  
  quantity   Int      @default(1)
  price      Float    // Precio congelado al momento de la compra
}

enum OrderStatus {
  PENDING
  PAID
  INGRAM_SYNCED
  SHIPPED
  CANCELLED
}

model Address {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nombres         String
  apellidos       String
  telefono        String
  calle           String
  numero          String
  numero_interior String?
  colonia         String
  codigo_postal   String
  ciudad          String
  estado          String
  referencias     String?
  active          Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TaxInvoice {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  razon_social  String
  rfc           String
  codigo_postal String
  regimen       String
  uso_de_cfdi   String
  forma_de_pago String
  active        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

